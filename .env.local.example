# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (server-side only — create these in your Stripe dashboard)
STRIPE_PRICE_BUILDER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Lightning (Voltage Cloud)
VOLTAGE_API_KEY=your_voltage_api_key
VOLTAGE_NODE_ID=your_voltage_node_id
LIGHTNING_ENABLED=false

# Resend (email notifications)
RESEND_API_KEY=re_your_resend_api_key

# Cron
CRON_SECRET=your_cron_secret

# Timelock Agent (demo auto-delivery)
ANTHROPIC_API_KEY=sk-ant-...
AGENT_SECRET=your_agent_secret_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
